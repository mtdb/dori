# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
eggs/
.eggs/
pip-wheel-metadata/
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/
venv.bak/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.tox/
*.pytest_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Mypy
.mypy_cache/

# Pyre
.pyre/

# Pytype
.pytype/

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# Local env files
.env
.env.*

# egg info produced by setup.py
*.egg-info/

# Ignore built wheel files
*.whl

# Project specific ignores
.worktrees/
docs/plans/
.poetry-cache/

# Ignore brainstorms, superpowers, and QA docs
docs/brainstorms/
docs/superpowers/
docs/qa/